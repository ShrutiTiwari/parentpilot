{
"rewrites": [
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ],
  "redirects": [
    {
      "source": "/music/visualize/:piece*",
      "destination": "https://falling-notes.vercel.app/:piece*",
      "permanent": false
    },
    {
      "source": "/music/visualize",
      "destination": "https://falling-notes.vercel.app/",
      "permanent": false
    }
  ]
}
